<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layoutDirection="rtl">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 محلل الفيديو الذكي"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1a1a1a"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="حلل فيديوك قبل النشر وارفع احتمالية الوصول للترند"
            android:textSize="13sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Niche Selector -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="اختر مجال الفيديو:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerNiche"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"/>

        <!-- Reference (trend) video learning -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📈 تعلّم من فيديو رائج (اختياري)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="الصق رابط فيديو TikTok ناجح ليتعلّم التطبيق وصفته ويطبّقها على فيديوهاتك"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etReferenceUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://www.tiktok.com/..."
                    android:textSize="13sp"
                    android:inputType="textUri"
                    android:layoutDirection="ltr"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnAnalyzeRef"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔍 حلّل الفيديو المرجعي"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF9800"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pick Video Button -->
        <Button
            android:id="@+id/btnPick"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📹 اختر فيديو من هاتفك"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvVideoName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#555555"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <!-- Analyze Button -->
        <Button
            android:id="@+id/btnAnalyze"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🤖 حلل الفيديو الآن"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#EE1D52"
            android:enabled="false"
            android:layout_marginBottom="8dp"/>

        <!-- Enhance Video Button -->
        <Button
            android:id="@+id/btnEnhance"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🎬 حسّن الفيديو للترند"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Trend Report Button -->
        <Button
            android:id="@+id/btnReport"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📊 تقرير الترند"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#9C27B0"
            android:layout_marginBottom="12dp"/>

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="اختر فيديو للبدء"
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- Results -->
        <ScrollView
            android:id="@+id/layoutResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Score Card -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="نقاط الانتشار"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="52sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvVerdict"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#444444"
                            android:gravity="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Quick Stats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        android:layout_marginEnd="6dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎣 الـ Hook"
                                android:textSize="12sp"
                                android:textColor="#888888"/>

                            <TextView
                                android:id="@+id/tvHook"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#333333"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        android:layout_marginStart="6dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⏱ المدة"
                                android:textSize="12sp"
                                android:textColor="#888888"/>

                            <TextView
                                android:id="@+id/tvDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#333333"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Strengths -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💪 نقاط القوة"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvStrengths"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:lineSpacingMultiplier="1.6"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Improvements -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔧 تحسينات مقترحة"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FF5722"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvImprovements"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:lineSpacingMultiplier="1.6"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Caption -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✍️ كابشن جاهز للنشر"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#2196F3"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvCaption"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Hashtags -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="# هاشتاقات مقترحة"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#9C27B0"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvHashtags"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#555555"
                            android:lineSpacingMultiplier="1.6"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Best Time + Transcript -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏰ أفضل وقت للنشر"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FF9800"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvBestTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎤 ما قيل في الفيديو"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#607D8B"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvTranscript"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Copy All Button -->
                <Button
                    android:id="@+id/btnCopyAll"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="📋 نسخ الكابشن والهاشتاقات"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2196F3"
                    android:layout_marginBottom="24dp"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</ScrollView>
